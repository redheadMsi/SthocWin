KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=your_account_number_here # 8자리 (예: 12345678)
KIS_ACCOUNT_PR=01 # 계좌상품코드 (보통 01)
KIS_MODE=VIRTUAL # VIRTUAL (모의투자) 또는 REAL (실전투자)

# 자동매매 설정
AUTO_TRADING=True # False로 설정 시 알림만 전송 (수동 매매 모드)

# ==========================================
# 알림 봇 설정 (Notification Settings)
# ==========================================
# 사용할 알림 채널을 쉼표(,)로 구분하여 입력 (예: DISCORD,SLACK,LINE)
NOTIFICATION_CHANNELS=DISCORD

# 1. 디스코드 (Discord)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# 2. 슬랙 (Slack)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# 3. 라인 (Line Notify) - https://notify-bot.line.me/ 에서 발급
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# 4. 카카오톡 (Kakao) - 나에게 보내기 API (갱신 필요)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_REFRESH_TOKEN=your_kakao_refresh_token_here
